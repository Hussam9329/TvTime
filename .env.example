# TvTime environment variables
# Copy this file to `.env` (local) or set them in your Vercel dashboard.

# ─── Required ────────────────────────────────────────────────────────────

# PostgreSQL connection string (Neon, Supabase, or local Postgres).
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# TMDB API key — request one at https://www.themoviedb.org/settings/api
TMDB_API_KEY="your_tmdb_api_key_here"

# ─── Authentication (production) ─────────────────────────────────────────
# When APP_PASSWORD is set, the site enforces login. When unset, the site
# runs in PUBLIC mode (legacy "personal app" behavior — anyone with the URL
# can read and write data).
#
# Optional: also set APP_USERNAME if you want the login form to require
# both a username AND a password (recommended).
APP_USERNAME=""
APP_PASSWORD=""

# Secret used to sign JWT session cookies. Must be at least 32 characters.
# Generate with:
#   openssl rand -base64 48 | tr -d '/+=\n'
SESSION_SECRET=""

# ─── Admin endpoints (optional) ──────────────────────────────────────────
# Protects /api/admin/* routes with a separate secret. Required to use the
# repair/backfill admin endpoints.
ADMIN_REPAIR_SECRET=""
