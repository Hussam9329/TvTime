// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String   @default("Cinephile")
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  watchlist       WatchlistItem[]
  watchedEpisodes WatchedEpisode[]
  watchedMovies   WatchedMovie[]
  ratings         Rating[]
  followingShows  FollowingShow[]
}

model WatchlistItem {
  id           String   @id @default(cuid())
  userId       String
  mediaType    String // "movie" | "tv"
  tmdbId       Int
  title        String
  posterPath   String?
  backdropPath String?
  overview     String?
  releaseDate  String?
  voteAverage  Float?
  addedAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaType, tmdbId])
  @@index([userId])
}

model WatchedMovie {
  id         String   @id @default(cuid())
  userId     String
  tmdbId     Int
  title      String
  posterPath String?
  runtime    Int?
  watchedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tmdbId])
  @@index([userId])
}

model WatchedEpisode {
  id            String   @id @default(cuid())
  userId        String
  showId        Int // TMDB show ID
  seasonNumber  Int
  episodeNumber Int
  episodeName   String?
  watchedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, showId, seasonNumber, episodeNumber])
  @@index([userId, showId])
}

model FollowingShow {
  id         String   @id @default(cuid())
  userId     String
  tmdbId     Int
  title      String
  posterPath String?
  followedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tmdbId])
  @@index([userId])
}

model Rating {
  id         String   @id @default(cuid())
  userId     String
  mediaType  String // "movie" | "tv"
  tmdbId     Int
  title      String
  posterPath String?
  value      Int // 1-10
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaType, tmdbId])
  @@index([userId])
}
