// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Unified Media model - tracks all types of media (movies, TV, books, games)
// Matches the HussamVision backup structure
model Media {
  id           String   @id // keep original ID from backup
  title        String
  originalTitle String?
  year         String?
  type         String   // "movie" | "series" | "book" | "game"
  poster       String?
  rating       String?  // TMDB/public rating as string
  overview     String?  @db.Text
  genres       String[] // array of genre names
  episodes     Int?
  seasons      Int?
  duration     String?
  status       String?  // "planned" | "watched" | "" | null
  author       String?
  pages        Int?
  tags         String[]
  notes        String?  @db.Text
  watched      Boolean  @default(false)
  watchedAt    DateTime?
  userRating   Int?     // 1-10 user rating
  rewatch      Boolean  @default(false)
  runtime      Int?
  ratingStatus String?  // "watched" | "planned" | null
  addedAt      DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([watched])
  @@index([userRating])
}
