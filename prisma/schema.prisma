// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  name            String           @default("Cinephile")
  avatar          String?
  timezone        String           @default("Asia/Baghdad")
  country         String           @default("IQ")
  preferredPlatforms String[]      @default([])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  media           Media[]
  watchlistItems  WatchlistItem[]
  watchedMovies   WatchedMovie[]
  watchedEpisodes WatchedEpisode[]
  followingShows  FollowingShow[]
  ratings         Rating[]
  watchSessions   WatchSession[]
  notifications   Notification[]
  importSessions  LibraryImportSession[]
}

/// Canonical media record - tracks movies and TV series.
model Media {
  id             String   @id @default(cuid())
  userId         String   @default("cinetrack_default")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tmdbId         Int?
  title          String
  originalTitle  String?
  year           String?
  type           String   // "movie" | "series"
  poster         String?
  rating         String?
  overview       String?
  genres         String[] @default([])
  episodes       Int?
  seasons        Int?
  duration       String?
  status         String?  // list/progress state; independent from isFollowing
  tags           String[] @default([])
  notes          String?
  watched        Boolean  @default(false)
  watchedAt      DateTime?
  userRating     Int?     // 0-100
  rewatch        Boolean  @default(false)
  runtime        Int?
  ratingStatus   String?
  isAnime        Boolean  @default(false)
  isArabic       Boolean  @default(false)
  originalLanguage String?
  originCountries String[] @default([])
  isFollowing    Boolean  @default(false)
  notifyOnNewEpisode Boolean?
  rewatchCount   Int      @default(0)
  addedAt        DateTime @default(now())
  updatedAt      DateTime @updatedAt

  watchSessions  WatchSession[]

  @@unique([userId, type, tmdbId], map: "Media_userId_type_tmdbId_key")
  @@index([userId])
  @@index([userId, type])
  @@index([userId, status])
  @@index([userId, watched])
  @@index([userId, userRating])
  @@index([userId, isAnime])
  @@index([userId, isArabic])
  @@index([tmdbId])
}

model WatchlistItem {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaType    String   // "movie" | "tv"
  tmdbId       Int
  title        String
  posterPath   String?
  backdropPath String?
  overview     String?
  releaseDate  String?
  voteAverage  Float?
  addedAt      DateTime @default(now())

  @@unique([userId, mediaType, tmdbId])
  @@index([userId])
}

model WatchedMovie {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId    Int
  title     String
  posterPath String?
  runtime   Int?
  watchedAt DateTime @default(now())

  @@unique([userId, tmdbId])
  @@index([userId])
}

model WatchedEpisode {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  showId        Int
  seasonNumber  Int
  episodeNumber Int
  episodeName   String?
  runtime       Int?
  watchedAt     DateTime @default(now())

  @@unique([userId, showId, seasonNumber, episodeNumber])
  @@index([userId])
  @@index([userId, showId])
}

model FollowingShow {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId     Int
  title      String
  posterPath String?
  followedAt DateTime @default(now())

  @@unique([userId, tmdbId])
  @@index([userId])
}

model Rating {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaType  String   // "movie" | "tv"
  tmdbId     Int
  title      String
  posterPath String?
  value      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, mediaType, tmdbId])
  @@index([userId])
}

/// Persistent server-side cache of TV show metadata from TMDB.
/// Populated lazily by src/lib/tv-status-server.ts to avoid re-fetching
/// every tracked show from TMDB on every /api/tv-tracking request.
/// Keyed by tmdbId (no userId — TMDB metadata is global, not per-user).
model TvMetadataCache {
  tmdbId                      Int      @id
  title                       String
  posterPath                  String?
  overview                    String?
  firstAirDate                String?
  originalLanguage            String?
  originCountries             String[] @default([])
  genreIds                    Int[]    @default([])
  genreNames                  String[] @default([])
  classificationComplete      Boolean  @default(false)
  tmdbStatus                  String?
  officiallyEnded             Boolean
  inProduction                Boolean?
  totalEpisodes               Int?
  totalSeasons                Int?
  airedEpisodeCount           Int?
  airedEpisodeKeys            String[] @default([])
  airedEpisodeInferenceReliable Boolean @default(false)
  nextEpisodeAirDate          String?
  nextEpisodeName             String?
  nextEpisodeSeasonNumber     Int?
  nextEpisodeEpisodeNumber    Int?
  seasonsCount                Int?
  lastSeasonNumber            Int?
  fetchedAt                   DateTime @default(now())
  refreshAfter                DateTime

  @@index([refreshAfter])
}

// ─────────────────────────────────────────────────────────────
// NEW ADDITIVE MODELS — TvTime+ features
// Added: Diary (WatchSession) and Notifications
// All defaults are safe — no migration of existing data needed.
// ─────────────────────────────────────────────────────────────

/// Diary entries — every watch session (movie or episode)
model WatchSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaId     String?
  media       Media?   @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  mediaType   String   // "movie" | "tv" | "anime" | "arabic_movie" | "arabic_tv"
  tmdbId      Int
  title       String
  season      Int?
  episode     Int?
  watchedAt   DateTime @default(now())
  duration    Int?     // minutes
  rewatch     Boolean  @default(false)
  rating      Int?     // 0-100 — rating at the time of session
  source      String?  // "Netflix" | "Cinema" etc.
  notes       String?
  createdAt   DateTime @default(now())

  @@index([userId, watchedAt])
  @@index([userId, mediaType])
  @@index([mediaId])
}

/// In-app notifications — episode alerts, movie availability, etc.
model Notification {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String   // "new_episode" | "movie_available" | "season_return" | "backlog_alert"
  title         String
  body          String
  tmdbId        Int?
  mediaType     String?
  read          Boolean  @default(false)
  scheduledFor  DateTime?
  createdAt     DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

/// Temporary, user-scoped staging session for a validated library restore.
model LibraryImportSession {
  id              String                @id @default(cuid())
  userId          String
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  version         Int
  status          String                @default("uploading")
  manifest        Json
  expectedRecords Int
  receivedRecords Int                   @default(0)
  expectedChunks  Int?
  receivedChunks  Int                   @default(0)
  preview         Json?
  result          Json?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  expiresAt       DateTime
  committedAt     DateTime?
  chunks          LibraryImportChunk[]
  records         LibraryImportRecord[]

  @@index([userId, status])
  @@index([expiresAt])
}

/// Idempotency marker for each uploaded import chunk.
model LibraryImportChunk {
  id          String               @id @default(cuid())
  sessionId   String
  session     LibraryImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sequence    Int
  checksum    String
  recordCount Int
  createdAt   DateTime             @default(now())

  @@unique([sessionId, sequence])
  @@index([sessionId])
}

/// A normalized and validated record waiting for the atomic import commit.
model LibraryImportRecord {
  id         String               @id @default(cuid())
  sessionId  String
  session    LibraryImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  collection String
  ordinal    Int
  payload    Json
  createdAt  DateTime             @default(now())

  @@unique([sessionId, collection, ordinal])
  @@index([sessionId, collection])
}
