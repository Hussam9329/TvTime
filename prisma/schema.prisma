// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  name            String           @default("Cinephile")
  avatar          String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  media           Media[]
  watchlistItems  WatchlistItem[]
  watchedMovies   WatchedMovie[]
  watchedEpisodes WatchedEpisode[]
  followingShows  FollowingShow[]
  ratings         Rating[]
}

/// Canonical media record - tracks all types of media (movies, TV, books, games)
model Media {
  id             String   @id @default(cuid())
  userId         String   @default("cinetrack_default")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tmdbId         Int?
  title          String
  originalTitle  String?
  year           String?
  type           String   // "movie" | "series" | "book" | "game"
  poster         String?
  rating         String?
  overview       String?
  genres         String[] @default([])
  episodes       Int?
  seasons        Int?
  duration       String?
  status         String?  // list/progress state; independent from isFollowing
  author         String?
  pages          Int?
  tags           String[] @default([])
  notes          String?
  watched        Boolean  @default(false)
  watchedAt      DateTime?
  userRating     Int?     // 0-100
  rewatch        Boolean  @default(false)
  runtime        Int?
  ratingStatus   String?
  isAnime        Boolean  @default(false)
  isFollowing    Boolean  @default(false)
  addedAt        DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, type, tmdbId], map: "Media_userId_type_tmdbId_key")
  @@index([userId])
  @@index([userId, type])
  @@index([userId, status])
  @@index([userId, watched])
  @@index([userId, userRating])
  @@index([userId, isAnime])
  @@index([tmdbId])
}

model WatchlistItem {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaType    String   // "movie" | "tv"
  tmdbId       Int
  title        String
  posterPath   String?
  backdropPath String?
  overview     String?
  releaseDate  String?
  voteAverage  Float?
  addedAt      DateTime @default(now())

  @@unique([userId, mediaType, tmdbId])
  @@index([userId])
}

model WatchedMovie {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId    Int
  title     String
  posterPath String?
  runtime   Int?
  watchedAt DateTime @default(now())

  @@unique([userId, tmdbId])
  @@index([userId])
}

model WatchedEpisode {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  showId        Int
  seasonNumber  Int
  episodeNumber Int
  episodeName   String?
  runtime       Int?
  watchedAt     DateTime @default(now())

  @@unique([userId, showId, seasonNumber, episodeNumber])
  @@index([userId])
  @@index([userId, showId])
}

model FollowingShow {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId     Int
  title      String
  posterPath String?
  followedAt DateTime @default(now())

  @@unique([userId, tmdbId])
  @@index([userId])
}

model Rating {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaType  String   // "movie" | "tv"
  tmdbId     Int
  title      String
  posterPath String?
  value      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, mediaType, tmdbId])
  @@index([userId])
}
