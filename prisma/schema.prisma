generator client {
  provider = "prisma-client-js"
}

// TVM-01: SQLite is the only supported database provider for this project.
// The packaged runtime, local development and build pipeline all use the same
// DATABASE_URL format: file:/absolute/or/relative/path.db
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String   @default("Cinephile")
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  media           Media[]
  watchedEpisodes WatchedEpisode[]

  // Deprecated migration-only relations. Runtime library APIs never read or
  // write these tables after TVM-01/02 canonicalization.
  legacyWatchlistItems  WatchlistItem[]
  legacyWatchedMovies   WatchedMovie[]
  legacyFollowingShows  FollowingShow[]
  legacyRatings         Rating[]
}

/// Canonical source of truth for every tracked movie/show/book/game.
///
/// `libraryState` is the only authoritative work-level state:
///   none | planned | watching | up_to_date | completed
///
/// `status` and `watched` are retained only as compatibility mirrors for old
/// clients/backups. All server writes derive them from `libraryState`.
model Media {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tmdbId        Int?
  title         String
  originalTitle String?
  year          String?
  type          String
  poster        String?
  rating        String?
  overview      String?
  genresJson    String @default("[]") @map("genres")
  episodes      Int?
  seasons       Int?
  duration      String?
  author        String?
  pages         Int?
  tagsJson      String @default("[]") @map("tags")
  notes         String?
  rewatch       Boolean @default(false)
  runtime       Int?
  ratingStatus  String?
  isAnime       Boolean @default(false)

  libraryState String   @default("none")
  stateChangedAt DateTime @default(now())
  watchedAt    DateTime?
  userRating   Int?

  // Deprecated compatibility mirrors. Never query these as source of truth.
  status  String?
  watched Boolean @default(false)

  addedAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type, tmdbId])
  @@index([userId])
  @@index([userId, type])
  @@index([userId, libraryState])
  @@index([userId, userRating])
  @@index([userId, isAnime])
  @@index([tmdbId])
}

model WatchedEpisode {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  showId        Int
  seasonNumber  Int
  episodeNumber Int
  episodeName   String?
  runtime       Int?
  watchedAt     DateTime @default(now())

  @@unique([userId, showId, seasonNumber, episodeNumber])
  @@index([userId])
  @@index([userId, showId])
}

model AppMeta {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Legacy migration-only models
// ---------------------------------------------------------------------------
// These tables remain mapped so existing SQLite files can be upgraded without
// data loss. New application code must use Media + WatchedEpisode only.

model WatchlistItem {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaType    String
  tmdbId       Int
  title        String
  posterPath   String?
  backdropPath String?
  overview     String?
  releaseDate  String?
  voteAverage  Float?
  addedAt      DateTime @default(now())

  @@unique([userId, mediaType, tmdbId])
  @@index([userId])
}

model WatchedMovie {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId     Int
  title      String
  posterPath String?
  runtime    Int?
  watchedAt  DateTime @default(now())

  @@unique([userId, tmdbId])
  @@index([userId])
}

model FollowingShow {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId     Int
  title      String
  posterPath String?
  followedAt DateTime @default(now())

  @@unique([userId, tmdbId])
  @@index([userId])
}

model Rating {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaType  String
  tmdbId     Int
  title      String
  posterPath String?
  value      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, mediaType, tmdbId])
  @@index([userId])
}
